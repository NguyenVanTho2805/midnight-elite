generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── COURSES ──────────────────────────────────────────────────────────────────

model Course {
  id            String   @id // slug: "hsa-tron-goi"
  adminId       Int      @unique
  sortOrder     Int      @unique @default(autoincrement()) // thứ tự hiển thị trên trang công khai (theo thứ tự tạo)
  name          String // tên công khai
  adminName     String // tên nội bộ
  shortTitle    String
  category      String
  instructor    String
  teacherAvatar String
  openDate      String
  types         String[]
  tag           String?
  tagColor      String?
  bg            String
  strip         String   @default("#FDE047")
  introVideo    String?
  zaloGroupLink String?
  price         Int
  originalPrice Int?
  lessons       Int      @default(0)
  hours         Int      @default(0)
  status        Boolean  @default(true)
  createdAt     String

  // Giáo viên sở hữu (null = nội dung cũ/của quản lý trung tâm). Chỉ dùng để
  // scope quyền khi User.adminRole === "teacher" — admin_super/admin_content
  // luôn thấy & sửa được mọi Course bất kể ownerId.
  ownerId String?
  owner   User?   @relation(fields: [ownerId], references: [id], onDelete: SetNull)

  sections    Section[]
  enrollments Enrollment[]
  favorites   CourseFavorite[]
  cartItems   CartItem[]
  reviews     CourseReview[]
  exams       Exam[]

  @@index([ownerId])
  @@map("courses")
}

model CartItem {
  userId    String
  courseId  String
  createdAt DateTime @default(now())

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@id([userId, courseId])
  @@map("cart_items")
}

model CourseFavorite {
  userId    String
  courseId  String
  createdAt DateTime @default(now())

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@id([userId, courseId])
  @@map("course_favorites")
}

model CourseReview {
  id        String   @id @default(cuid())
  userId    String
  courseId  String
  rating    Int // 1–5
  comment   String   @db.Text
  status    String   @default("pending") // "pending" | "approved" | "rejected"
  createdAt DateTime @default(now())

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@unique([userId, courseId])
  @@index([courseId, status])
  @@map("course_reviews")
}

// ─── CURRICULUM ───────────────────────────────────────────────────────────────

model Section {
  id       String    @id
  title    String
  order    Int       @default(0)
  courseId String
  course   Course    @relation(fields: [courseId], references: [id], onDelete: Cascade)
  chapters Chapter[]

  @@map("sections")
}

model Chapter {
  id        String   @id
  title     String
  order     Int      @default(0)
  sectionId String
  section   Section  @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  lessons   Lesson[]

  @@map("chapters")
}

model Lesson {
  id             String           @id
  code           String
  title          String
  type           String // "record" | "live" | "quiz" | "document"
  duration       String?
  videoUrl       String?
  zoomUrl        String?
  azotaUrl       String?
  azotaDeadline  String?
  documents      String?          @default("[]")
  adminNote      String?
  isLocked       Boolean          @default(true)
  isFree         Boolean          @default(false)
  statsVideos    Int              @default(0)
  statsMaterials Int              @default(0)
  statsViews     Int              @default(0)
  order          Int              @default(0)
  chapterId      String
  chapter        Chapter          @relation(fields: [chapterId], references: [id], onDelete: Cascade)
  progress       LessonProgress[]
  notes          LessonNote[]

  @@map("lessons")
}

// ─── EXAMS ────────────────────────────────────────────────────────────────────

model Exam {
  id           String  @id
  code         String  @unique
  title        String
  category     String
  date         String
  time         String
  duration     String
  questions    Int
  status       String // "upcoming" | "available" | "completed"
  azotaUrl     String? @default("")
  participants Int     @default(0)
  active       Boolean @default(true)
  activeGuest  Boolean @default(true)
  guestCanTake Boolean @default(false)
  createdAt    String

  // Xem ghi chú ở Course.ownerId — cùng quy tắc scope quyền.
  ownerId String?
  owner   User?   @relation(fields: [ownerId], references: [id], onDelete: SetNull)

  // Đề thi có thể gắn với 1 khoá học cụ thể (null = đề thi chung, không thuộc
  // khoá nào). Dùng để quyết định ai được thi miễn phí khi có price: học viên
  // đã Enrollment vào courseId này thì miễn phí, còn lại phải có ExamGuestAccess.
  courseId String?
  course   Course? @relation(fields: [courseId], references: [id], onDelete: SetNull)

  // null/0 = miễn phí cho tất cả (theo activeGuest/guestCanTake như cũ).
  // Có giá trị = học viên đã đăng ký courseId ở trên thi miễn phí, người khác
  // (guest hoặc học viên khoá khác) cần được duyệt qua ExamGuestAccess.
  price Int?

  // Thang % điểm câu Đúng-Sai 4 ý theo số ý trả lời đúng — mảng 4 số [1 ý,
  // 2 ý, 3 ý, 4 ý đúng] tính theo %, vd [10,25,50,100]. null = dùng mặc định
  // (xem CLUSTER_PERCENT_BY_CORRECT_COUNT trong src/lib/examGrading.ts).
  clusterScorePercents Json?

  // Tổng điểm hiển thị cuối cùng cho học viên (thang quy đổi, KHÁC với tổng
  // điểm thô = sum(ExamQuestion.points)) — điểm thô luôn được rescale về
  // đúng thang này khi chấm (xem finalizeAttempt/regradeAttempt trong
  // src/lib/examGrading.ts). Mặc định 150 để khớp hành vi hardcode trước đây.
  totalPoints Float @default(150)

  // null = không yêu cầu mật khẩu. Có giá trị = học viên phải nhập đúng mật
  // khẩu này mới bắt đầu làm bài được (đọc tại chỗ trong phòng thi có giám
  // sát, giống Azota) — KHÔNG BAO GIỜ trả field này qua API GET, chỉ trả
  // `hasPassword: boolean` (xem exams/route.ts, exams/[id]/route.ts).
  password String?

  // true = học viên xem được bảng xếp hạng Top 10 của đề này; false = ẩn
  // hoàn toàn (giáo viên không muốn học viên so điểm công khai).
  showLeaderboard Boolean @default(true)

  // Khi nào học viên xem được màn "Xem lại bài làm" (đáp án đúng/giải thích):
  // "never" | "after_submit" (ngay sau khi nộp) | "after_exam_ends" (chỉ sau
  // khi hết thời hạn làm bài của đề — tính từ date+time+duration, xem
  // hasExamWindowEnded() trong src/lib/examGrading.ts).
  answerVisibility String @default("after_submit")

  // true = câu học sinh trả lời SAI chỉ hiện "Sai", không lộ đáp án đúng thật
  // (chặn kiểu nộp bừa để dò đáp án rồi thi lại) — áp dụng khi answerVisibility
  // đã cho phép xem đáp án. Câu trả lời ĐÚNG vẫn luôn hiện đáp án bình thường.
  hideAnswerForWrong Boolean @default(false)

  results       ExamResult[]
  examQuestions ExamQuestion[]
  attempts      ExamAttempt[]
  guestAccess   ExamGuestAccess[]

  @@index([ownerId])
  @@index([courseId])
  @@map("exams")
}

// Câu hỏi thi trắc nghiệm trong platform — KHÔNG liên quan đến model
// Question/Answer bên dưới (đó là module Hỏi Đáp cộng đồng, khác hoàn toàn).
model ExamQuestion {
  id          String   @id
  examId      String
  order       Int      @default(0)
  text        String   @db.Text
  imageUrl    String?
  points      Float    @default(1)
  explanation String?  @db.Text
  createdAt   DateTime @default(now())

  // "MC" (trắc nghiệm 1 đáp án, mặc định) | "ESSAY" (tự luận, chấm tay) |
  // "TRUE_FALSE_CLUSTER" (1 đoạn dẫn + 4 mệnh đề con, mỗi ý tự đúng/sai độc
  // lập — không phải chọn 1 trong 4, xem ExamOption.subLabel/ExamAnswerBoolean) |
  // "SHORT_ANSWER" (điền đáp án ngắn, chấm tự động so khớp text — đáp án đúng
  // lưu trong ExamOption duy nhất của câu, xem examGrading.ts).
  type String @default("MC")

  // Tên Phần thi (vd "Phần Trắc nghiệm") để nhóm hiển thị — null = không
  // thuộc phần nào (đề cũ, hoặc đề không cần chia phần). Chỉ dùng để nhóm
  // hiển thị + xáo trong phạm vi từng phần (shuffleQuestionOrderBySections
  // trong examGrading.ts), không ảnh hưởng tới cách tính điểm.
  sectionLabel String?

  exam    Exam         @relation(fields: [examId], references: [id], onDelete: Cascade)
  options ExamOption[]
  answers ExamAnswer[]

  @@index([examId, order])
  @@map("exam_questions")
}

model ExamOption {
  id         String  @id
  questionId String
  order      Int     @default(0) // vị trí A/B/C/D suy ra từ order, không lưu chữ cái
  text       String  @db.Text
  // MC: đây có phải đáp án đúng không. TRUE_FALSE_CLUSTER: mệnh đề này có
  // đúng không (giá trị đúng/sai thật của phát biểu, không phải câu trả lời
  // của học sinh — câu trả lời của học sinh nằm ở ExamAnswerBoolean).
  isCorrect  Boolean @default(false)
  // Chỉ dùng cho TRUE_FALSE_CLUSTER: "a" | "b" | "c" | "d" — null với MC/ESSAY.
  subLabel   String?

  question       ExamQuestion        @relation(fields: [questionId], references: [id], onDelete: Cascade)
  answers        ExamAnswer[]
  booleanAnswers ExamAnswerBoolean[]

  @@index([questionId])
  @@map("exam_options")
}

// Một lần học viên làm bài. Thời gian làm bài enforce ở server qua expiresAt,
// không tin đồng hồ đếm ngược phía client.
model ExamAttempt {
  id          String    @id @default(cuid())
  userId      String
  examId      String
  startedAt   DateTime  @default(now())
  expiresAt   DateTime
  submittedAt DateTime?
  status      String    @default("in_progress") // "in_progress" | "submitted" | "expired"
  score       Float?
  totalPoints Float? // snapshot sum(points) lúc bắt đầu

  // Snapshot thứ tự đã xáo lúc tạo attempt — cố định suốt 1 lượt, xáo lại
  // hoàn toàn ở lượt sau. questionOrder: mảng ExamQuestion.id theo thứ tự
  // hiển thị. optionOrderByQuestion: { [questionId]: ExamOption.id[] }.
  questionOrder         Json?
  optionOrderByQuestion Json?

  // Giám sát thoát tab/rời màn hình — chỉ đếm sự kiện, không quay màn hình
  // (giống cơ chế Azota). tabSwitchLog: mảng ISO timestamp mỗi lần rời tab.
  tabSwitchCount Int   @default(0)
  tabSwitchLog   Json?

  user           User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  exam           Exam                @relation(fields: [examId], references: [id], onDelete: Cascade)
  answers        ExamAnswer[]
  booleanAnswers ExamAnswerBoolean[]

  @@index([userId, examId])
  @@index([examId, status])
  @@map("exam_attempts")
}

// Trả lời cho câu MC (optionId) hoặc ESSAY (textAnswer) — 1 câu hỏi luôn có
// đúng 1 dòng ExamAnswer/attempt. Câu TRUE_FALSE_CLUSTER dùng bảng riêng
// ExamAnswerBoolean bên dưới vì cần 4 câu trả lời độc lập cho 1 câu hỏi.
model ExamAnswer {
  id         String   @id @default(cuid())
  attemptId  String
  questionId String
  optionId   String? // null = chưa trả lời (MC) hoặc câu ESSAY
  textAnswer String?  @db.Text // chỉ dùng cho câu ESSAY
  answeredAt DateTime @updatedAt

  // Chấm tay câu ESSAY (Giai đoạn 6) — null = chưa chấm, không phải 0 điểm.
  // Không dùng cho MC/CLUSTER (chấm tự động lúc nộp bài).
  pointsAwarded  Float?
  teacherComment String? @db.Text

  attempt  ExamAttempt  @relation(fields: [attemptId], references: [id], onDelete: Cascade)
  question ExamQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)
  option   ExamOption?  @relation(fields: [optionId], references: [id], onDelete: SetNull)

  @@unique([attemptId, questionId])
  @@map("exam_answers")
}

// Trả lời cho từng mệnh đề con (subLabel a/b/c/d) của 1 câu TRUE_FALSE_CLUSTER
// — mỗi mệnh đề là 1 dòng riêng vì học sinh đánh đúng/sai độc lập cho từng ý,
// không phải chọn 1 trong 4 như MC (nên không dùng chung ExamAnswer được).
model ExamAnswerBoolean {
  id         String   @id @default(cuid())
  attemptId  String
  optionId   String // ExamOption của mệnh đề con (có subLabel)
  answerTrue Boolean? // null = chưa trả lời ý này
  answeredAt DateTime @updatedAt

  attempt ExamAttempt @relation(fields: [attemptId], references: [id], onDelete: Cascade)
  option  ExamOption  @relation(fields: [optionId], references: [id], onDelete: Cascade)

  @@unique([attemptId, optionId])
  @@map("exam_answer_booleans")
}

// Admin (trung tâm/giáo viên sở hữu đề) gắn cờ này thủ công sau khi xác nhận
// guest đã trả phí qua quy trình sales hiện có (KHÔNG có cổng thanh toán tự
// động — xem plan Giai đoạn 3, reports/2026-07-13.md). Có bản ghi = được thi.
model ExamGuestAccess {
  id        String   @id @default(cuid())
  userId    String
  examId    String
  grantedBy String // userId của admin/giáo viên đã duyệt
  grantedAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  exam Exam @relation(fields: [examId], references: [id], onDelete: Cascade)

  @@unique([userId, examId])
  @@map("exam_guest_access")
}

// ─── USERS ────────────────────────────────────────────────────────────────────

model User {
  id            String   @id @default(cuid())
  name          String
  email         String   @unique
  password      String
  phone         String?
  parentPhone   String?
  parentName    String?
  school        String?
  highSchool    String?
  city          String?
  studentId     Int?     @unique
  avatarBase64  String?  @db.Text
  facebookUrl   String?
  zaloPhone     String?
  role          String   @default("student") // "student" | "admin"
  adminRole     String? // "admin_super" | "admin_content" | "teacher"
  emailVerified Boolean  @default(false)
  banned        Boolean  @default(false)
  createdAt     DateTime @default(now())

  ownedCourses        Course[]
  ownedExams          Exam[]
  examGuestAccess     ExamGuestAccess[]
  enrollments         Enrollment[]
  verifyTokens        VerifyToken[]
  passwordResetTokens PasswordResetToken[]
  lessonProgress      LessonProgress[]
  lessonNotes         LessonNote[]
  courseFavorites     CourseFavorite[]
  cartItems           CartItem[]
  courseReviews       CourseReview[]
  notifications       Notification[]
  examResults         ExamResult[]
  examAttempts        ExamAttempt[]
  badges              UserBadge[]
  threads             Thread[]
  threadReplies       ThreadReply[]
  threadLikes         ThreadLike[]
  replyLikes          ReplyLike[]
  threadBookmarks     ThreadBookmark[]
  wallet              Wallet?
  coinTransactions    CoinTransaction[]
  questions           Question[]
  answers             Answer[]
  answerReports       AnswerReport[]
  threadReports       ThreadReport[]

  @@map("users")
}

model VerifyToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  expiresAt DateTime
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("verify_tokens")
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  expiresAt DateTime
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("password_reset_tokens")
}

// ─── ENROLLMENTS ──────────────────────────────────────────────────────────────

model Enrollment {
  id        String   @id @default(cuid())
  userId    String
  courseId  String
  createdAt DateTime @default(now())

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@unique([userId, courseId])
  @@map("enrollments")
}

// ─── NOTIFICATIONS ────────────────────────────────────────────────────────────

model Notification {
  id        String   @id @default(cuid())
  userId    String
  type      String // "enrollment" | "exam_new" | "exam_reminder" | "thread_reply" | "thread_like" | "reply_like" | "article_new"
  title     String
  message   String
  link      String?
  isRead    Boolean  @default(false)
  count     Int      @default(1) // số lượt gộp — vd "X và 4 người khác đã thích..."
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead])
  @@map("notifications")
}

// ─── LESSON PROGRESS ──────────────────────────────────────────────────────────

model LessonProgress {
  id             String   @id @default(cuid())
  userId         String
  lessonId       String
  completedAt    DateTime @default(now())
  watchedSeconds Int      @default(0)

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  lesson Lesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@unique([userId, lessonId])
  @@map("lesson_progress")
}

// ─── LESSON NOTES ─────────────────────────────────────────────────────────────
// Ghi chú cá nhân của học sinh cho từng bài học — trước đây lưu localStorage
// nên không đồng bộ giữa các thiết bị (mobile/web riêng), giờ lưu DB thật.

model LessonNote {
  id        String   @id @default(cuid())
  userId    String
  lessonId  String
  text      String   @db.Text
  updatedAt DateTime @updatedAt

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  lesson Lesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@unique([userId, lessonId])
  @@map("lesson_notes")
}

// ─── EXAM RESULTS ─────────────────────────────────────────────────────────────

model ExamResult {
  id          String   @id @default(cuid())
  userId      String
  examId      String
  score       Float
  totalPoints Int      @default(150)
  completedAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  exam Exam @relation(fields: [examId], references: [id], onDelete: Cascade)

  @@unique([userId, examId])
  @@map("exam_results")
}

// ─── BADGES ───────────────────────────────────────────────────────────────────

model UserBadge {
  id        String   @id @default(cuid())
  userId    String
  badgeId   String
  grantedAt DateTime @default(now())
  grantedBy String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, badgeId])
  @@map("user_badges")
}

// ─── COMMUNITY ────────────────────────────────────────────────────────────────

model Thread {
  id        String    @id @default(cuid())
  content   String    @db.Text
  authorId  String
  category  String    @default("hoi-dap")
  isPinned  Boolean   @default(false)
  imageUrls String[]
  fileUrl   String?
  fileName  String?
  deletedAt DateTime? // soft-delete — xoá thật để lại dấu vết, tránh mất bằng chứng khi có tranh chấp
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  author    User             @relation(fields: [authorId], references: [id], onDelete: Cascade)
  replies   ThreadReply[]
  likes     ThreadLike[]
  bookmarks ThreadBookmark[]
  reports   ThreadReport[]

  @@map("threads")
}

model ThreadReport {
  id         String   @id @default(cuid())
  threadId   String
  reporterId String
  reason     String
  status     String   @default("pending") // "pending" | "approved" | "rejected"
  createdAt  DateTime @default(now())

  thread   Thread @relation(fields: [threadId], references: [id], onDelete: Cascade)
  reporter User   @relation(fields: [reporterId], references: [id], onDelete: Cascade)

  @@unique([threadId, reporterId])
  @@map("thread_reports")
}

model ThreadReply {
  id        String    @id @default(cuid())
  content   String    @db.Text
  authorId  String
  threadId  String
  imageUrls String[]
  deletedAt DateTime? // soft-delete, xem giải thích ở Thread.deletedAt
  createdAt DateTime  @default(now())

  author User        @relation(fields: [authorId], references: [id], onDelete: Cascade)
  thread Thread      @relation(fields: [threadId], references: [id], onDelete: Cascade)
  likes  ReplyLike[]

  @@map("thread_replies")
}

model ThreadLike {
  userId   String
  threadId String

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  thread Thread @relation(fields: [threadId], references: [id], onDelete: Cascade)

  @@id([userId, threadId])
  @@map("thread_likes")
}

model ReplyLike {
  userId  String
  replyId String

  user  User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  reply ThreadReply @relation(fields: [replyId], references: [id], onDelete: Cascade)

  @@id([userId, replyId])
  @@map("reply_likes")
}

model ThreadBookmark {
  userId    String
  threadId  String
  createdAt DateTime @default(now())

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  thread Thread @relation(fields: [threadId], references: [id], onDelete: Cascade)

  @@id([userId, threadId])
  @@map("thread_bookmarks")
}

// ─── COIN ECONOMY & HỎI ĐÁP (Knowledge Bounty) ────────────────────────────────
// Đặt câu hỏi mất xu (phí cố định), trả lời được chấp nhận nhận xu thưởng
// (hệ thống cấp riêng, không lấy từ phí người hỏi). Report sai/spam do admin
// duyệt — nếu đúng, trừ lại xu thưởng đã nhận.

model Wallet {
  userId  String @id
  balance Int    @default(0)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("wallets")
}

model CoinTransaction {
  id        String   @id @default(cuid())
  userId    String
  amount    Int // dương = cộng, âm = trừ
  reason    String // "signup_bonus" | "question_cost" | "answer_reward" | "report_penalty"
  refId     String? // id câu hỏi/trả lời liên quan (để truy vết)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("coin_transactions")
}

model Question {
  id               String   @id @default(cuid())
  authorId         String
  title            String
  content          String   @db.Text
  bountyPaid       Int // số xu đã trừ khi đăng (lưu lại để minh bạch)
  status           String   @default("open") // "open" | "answered"
  acceptedAnswerId String?  @unique
  createdAt        DateTime @default(now())

  author         User     @relation(fields: [authorId], references: [id], onDelete: Cascade)
  answers        Answer[] @relation("QuestionAnswers")
  acceptedAnswer Answer?  @relation("AcceptedAnswer", fields: [acceptedAnswerId], references: [id])

  @@map("questions")
}

model Answer {
  id          String   @id @default(cuid())
  questionId  String
  authorId    String
  content     String   @db.Text
  rewardPaid  Int? // số xu đã thưởng (null nếu chưa được chấp nhận)
  isPenalized Boolean  @default(false) // đã bị admin duyệt report và trừ xu
  createdAt   DateTime @default(now())

  question    Question       @relation("QuestionAnswers", fields: [questionId], references: [id], onDelete: Cascade)
  author      User           @relation(fields: [authorId], references: [id], onDelete: Cascade)
  acceptedFor Question?      @relation("AcceptedAnswer")
  reports     AnswerReport[]

  @@map("answers")
}

model AnswerReport {
  id         String   @id @default(cuid())
  answerId   String
  reporterId String
  reason     String
  status     String   @default("pending") // "pending" | "approved" | "rejected"
  createdAt  DateTime @default(now())

  answer   Answer @relation(fields: [answerId], references: [id], onDelete: Cascade)
  reporter User   @relation(fields: [reporterId], references: [id], onDelete: Cascade)

  @@unique([answerId, reporterId])
  @@map("answer_reports")
}

// ─── TSIX SALES BOT (lead/hội thoại tư vấn, ghi từ service Python riêng) ──────

model SalesLead {
  id                  String   @id @default(cuid())
  sessionId           String   @unique // session_id sinh ở widget chat (localStorage)
  leadScore           Int      @default(0)
  stage               String   @default("awareness") // awareness | consideration | decision
  conversationSummary String   @default("") @db.Text
  escalationFlag      Boolean  @default(false)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  messages SalesMessage[]

  @@map("sales_leads")
}

model SalesMessage {
  id        String   @id @default(cuid())
  leadId    String
  role      String // "user" | "bot"
  text      String   @db.Text
  createdAt DateTime @default(now())

  lead SalesLead @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@map("sales_messages")
}

// ─── NEWS / ARTICLES ──────────────────────────────────────────────────────────

model Article {
  id          String    @id @default(cuid())
  slug        String    @unique
  title       String
  excerpt     String    @db.Text
  content     String    @db.Text
  category    String
  author      String
  authorId    String
  tag         String?
  isPinned    Boolean   @default(false)
  published   Boolean   @default(false)
  readTime    Int       @default(5)
  views       Int       @default(0)
  publishedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@map("articles")
}
